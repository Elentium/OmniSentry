--[[
    String255 read operation
]]
@native
const function reads255(cursor: cursor): (number, string?)
	local offset: number = cursor.offset
	const len: number = cursor.len
	const buf: buffer = cursor.buf

	if offset + 1 > len then
		return FAIL, nil
	end

	const strlen: number = READ_U8(buf, offset)
	offset += 1
	if offset + strlen > len then
		return FAIL, nil
	end

	const value: string = READ_STRING(buf, offset, strlen)
	offset += strlen
	cursor.offset = offset
	return offset == len and EOR or SUCCESS, value
end

--[[
    String65535 read operation
]]
@native
const function reads65(cursor: cursor): (number, string?)
	local offset: number = cursor.offset
	const len: number = cursor.len
	const buf: buffer = cursor.buf

	if offset + 2 > len then
		return FAIL, nil
	end
	const strlen: number = READ_U16(buf, offset)
	offset += 2
	if offset + strlen > len then
		return FAIL, nil
	end

	const value: string = READ_STRING(buf, offset, strlen)
	offset += strlen
	cursor.offset = offset
	return offset == len and EOR or SUCCESS, value
end

@native const function readu40(cursor: cursor): (number, number?)
	local offset: number = cursor.offset
	const len: number = cursor.len
	const buf: buffer = cursor.buf

	if offset + 5 > len then
		return FAIL, nil
	end
	const lower: number = READ_U32(buf, offset)
	offset += 4
	const upper: number = READ_U8(buf, offset)
	offset += 1
	cursor.offset = offset

	const value: number = upper * 0x100000000 + lower

	return offset == len and EOR or SUCCESS, value
end

@native const function readi40(cursor: cursor): (number, number?)
	local offset: number = cursor.offset
	const len: number = cursor.len
	const buf: buffer = cursor.buf

	if offset + 5 > len then
		return FAIL, nil
	end
	const lower: number = READ_U32(buf, offset)
	offset += 4
	const upper: number = READ_U8(buf, offset)
	offset += 1
	cursor.offset = offset

	local value: number = upper * 0x100000000 + lower
	if upper >= 0x80 then
		value -= 0x10000000000
	end

	return offset == len and EOR or SUCCESS, value
end

