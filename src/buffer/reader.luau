--[[
    Float16 read operation
    Unpacks 1s|5e(bias15)|10m.
    Special values: ±Inf and NaN are preserved.
]]
@native
const function readf16(cursor: cursor): (number, number?)
	local offset: number = cursor.offset
	const len: number = cursor.len

	if offset + 2 > len then
		return FAIL, nil
	end

	const packed: number = READ_U16(cursor.buf, offset)
	offset += 2
	cursor.offset = offset

	const sign: number = EXTRACT(packed, 15, 1)
	const exp16: number = EXTRACT(packed, 10, 5)
	const mant10: number = EXTRACT(packed, 0, 10)

	local result: number
	if exp16 == 0x1F then
		result = if mant10 ~= 0 then 0 / 0 else math.huge
	elseif exp16 == 0 then
		result = 0
	else
		-- Normal: (1 + mant10/1024) * 2^(exp16 - 15)
		result = LDEXP(1 + mant10 / 1024, exp16 - 15)
	end

	if sign == 1 then
		result = -result
	end

	return offset == len and EOR or SUCCESS, result
end

--[[
    UInt24 read operation
]]
@native
const function readu24(cursor: cursor): (number, number?)
	local offset: number = cursor.offset
	const len: number = cursor.len
	const buf: buffer = cursor.buf

	if offset + 3 > len then
		return FAIL, nil
	end

	const low: number = READ_U16(buf, offset)
	const high: number = READ_U8(buf, offset + 2)
	offset += 3
	cursor.offset = offset
	return offset == len and EOR or SUCCESS, OR(low, LSHIFT(high, 16))
end

--[[
    Int24 read operation
]]
@native
const function readi24(cursor: cursor): (number, number?)
	local offset: number = cursor.offset
	const len: number = cursor.len
	const buf: buffer = cursor.buf

	if offset + 3 > len then
		return FAIL, nil
	end

	const low: number = READ_U16(buf, offset)
	const high: number = READ_U8(buf, offset + 2)
	offset += 3
	cursor.offset = offset

	local value: number = OR(low, LSHIFT(high, 16))
	-- bit32.arshift returns an unsigned 32-bit number; manually sign-extend to 24-bit.
	if value >= 0x800000 then
		value = value - 0x1000000
	end
	return offset == len and EOR or SUCCESS, value
end

--[[
    Float24 read operation
    Unpacks 16m | (1s | 7e(bias63)).
    Special values: ±Inf and NaN are preserved (exp24=0x7F).
]]
@native
const function readf24(cursor: cursor): (number, number?)
	local offset: number = cursor.offset
	const len: number = cursor.len
	const buf: buffer = cursor.buf

	if offset + 3 > len then
		return FAIL, nil
	end

	const mant16: number = READ_U16(buf, offset)
	const byte2: number = READ_U8(buf, offset + 2)
	offset += 3
	cursor.offset = offset

	const sign: number = EXTRACT(byte2, 7, 1)
	const exp24: number = AND(byte2, 0x7F)

	local result: number
	if exp24 == 0x7F then
		result = if mant16 ~= 0 then 0 / 0 else math.huge
	elseif exp24 == 0 then
		result = 0
	else
		-- Normal: (1 + mant16/65536) * 2^(exp24 - 63)
		result = LDEXP(1 + mant16 / 65536, exp24 - 63)
	end

	if sign == 1 then
		result = -result
	end

	return offset == len and EOR or SUCCESS, result
end

