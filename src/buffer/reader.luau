@native const function readcolor3(cursor: cursor): (number, Color3?)
	local offset: number = cursor.offset
	const len: number = cursor.len
	const buf: buffer = cursor.buf

	if offset + 3 > len then
		return FAIL, nil
	end
	const r: number = READ_U8(buf, offset)
	offset += 1
	const g: number = READ_U8(buf, offset)
	offset += 1
	const b: number = READ_U8(buf, offset)
	offset += 1
	cursor.offset = offset
	return offset == len and EOR or SUCCESS, COLOR3_FROM_RGB(r, g, b)
end

