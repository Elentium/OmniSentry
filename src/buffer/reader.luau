--[[
    Int16 read operation
]]
@native
const function readi16(cursor: cursor): (number, number?)
	local offset: number = cursor.offset
	const len: number = cursor.len

	if offset + 2 > len then
		return FAIL, nil
	end

	const value: number = READ_I16(cursor.buf, offset)
