@native const function readv2f32(cursor: cursor): (number, Vector2?)
	local offset: number = cursor.offset
	const len: number = cursor.len
	const buf: buffer = cursor.buf

	if offset + 8 > len then
		return FAIL, nil
	end
	const x: number = READ_F32(buf, offset)
	offset += 4
	const y: number = READ_F32(buf, offset)
	offset += 4
	cursor.offset = offset
	return offset == len and EOR or SUCCESS, VECTOR2_NEW(x, y)
end

@native const function readv2f24(cursor: cursor): (number, Vector2?)
	local offset: number = cursor.offset
	const len: number = cursor.len

	if offset + 6 > len then
		return FAIL, nil
	end
	const _, vx = readf24(cursor)
	const __, vy = readf24(cursor)
	return offset + 6 == len and EOR or SUCCESS, VECTOR2_NEW(vx :: number, vy :: number)
end

